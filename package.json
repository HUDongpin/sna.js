{
  "name": "@peterhudongpin/sna.js",
  "version": "0.3.1",
  "description": "A browser-compatible TypeScript/JavaScript port of the R sna social network analysis package.",
  "type": "module",
  "sideEffects": false,
  "license": "GPL-2.0-or-later",
  "author": "Dongpin Hu <hudongpin123@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HUDongpin/sna.js.git"
  },
  "homepage": "https://github.com/HUDongpin/sna.js#readme",
  "bugs": {
    "url": "https://github.com/HUDongpin/sna.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "unpkg": "./dist/browser.min.js",
  "jsdelivr": "./dist/browser.min.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./display": {
      "types": "./dist/display/index.d.ts",
      "import": "./dist/display/index.js",
      "require": "./dist/display/index.cjs"
    },
    "./compat": {
      "types": "./dist/compat.d.ts",
      "import": "./dist/compat.js",
      "require": "./dist/compat.cjs"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js",
      "require": "./dist/worker/index.cjs"
    },
    "./visualization": {
      "types": "./dist/visualization/index.d.ts",
      "import": "./dist/visualization/index.js",
      "require": "./dist/visualization/index.cjs"
    },
    "./visualization/three": {
      "types": "./dist/visualization/three.d.ts",
      "import": "./dist/visualization/three.js",
      "require": "./dist/visualization/three.cjs"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "examples",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "r:parity": "Rscript scripts/generate-r-snapshots.R",
    "example:node": "npm run build && node examples/node.mjs",
    "smoke:examples": "node scripts/smoke-examples.mjs",
    "size:check": "node scripts/check-size.mjs",
    "check:publish": "npm test && npm run typecheck && npm run build && npm run smoke:examples && npm run size:check && npm pack --dry-run",
    "prepublishOnly": "npm test && npm run typecheck && npm run build"
  },
  "keywords": [
    "sna",
    "social-network-analysis",
    "graph",
    "network-analysis",
    "centrality",
    "network-science",
    "typescript",
    "javascript"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^3.2.7",
    "three": "^0.184.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.7"
  },
  "peerDependencies": {
    "three": "^0.184.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
